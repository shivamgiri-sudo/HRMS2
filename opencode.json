{
  "$schema": "https://opencode.ai/config.json",
  "model": "bedrock/anthropic.claude-sonnet-4-5-20250929-v1:0",
  "small_model": "bedrock/us.anthropic.claude-haiku-4-5-20251001-v1:0",
  "enabled_providers": ["bedrock"],
  "provider": {
    "bedrock": {
      "options": {
        "profile": "bedrock",
        "region": "ap-south-1"
      }
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    }
  }
}
