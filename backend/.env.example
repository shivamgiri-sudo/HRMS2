NODE_ENV=development
PORT=5055
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:5055

ACTIVE_DB_PROVIDER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_staging_db
DB_POOL_MAX=10

JWT_SECRET=replace-with-strong-local-jwt-secret-at-least-32-chars
PORTAL_JWT_SECRET=replace-with-strong-local-portal-secret-at-least-32-chars
PAYROLL_BANK_KEY=replace-with-strong-bank-key
ENCRYPTION_KEY=replace-with-64-hex-character-key

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=MAS Callnet HRMS

BILL_DB_HOST=127.0.0.1
BILL_DB_PORT=3306
BILL_DB_USER=your_bill_db_user
BILL_DB_PASSWORD=your_bill_db_password
BILL_DB_NAME=db_bill

DIALER_DB_HOST=127.0.0.1
DIALER_DB_PORT=3306
DIALER_DB_USER=your_dialer_db_user
DIALER_DB_PASSWORD=your_dialer_db_password
DIALER_DB_NAME=dialer_db

LEGACY_MYSQL_HOST=127.0.0.1
LEGACY_MYSQL_PORT=3306
LEGACY_MYSQL_USER=your_legacy_user
LEGACY_MYSQL_PASSWORD=your_legacy_password
LEGACY_MYSQL_DATABASE=db_bill
LEGACY_MYSQL_LOCAL_ADDRESS=

LMS_DB_HOST=127.0.0.1
LMS_DB_PORT=3306
LMS_DB_USER=your_lms_user
LMS_DB_PASSWORD=your_lms_password
LMS_DB_NAME=lms_mcn

NCOSEC_DB_HOST=127.0.0.1
NCOSEC_DB_PORT=1433
NCOSEC_DB_USER=your_ncosec_user
NCOSEC_DB_PASSWORD=your_ncosec_password
NCOSEC_DB_NAME=NCOSEC
NCOSEC_DB_ENCRYPT=false

BGV_WEBHOOK_SECRET=replace-with-bgv-webhook-secret
ATS_FORM_API_KEY=replace-with-ats-form-api-key
INFINITY_AI_API_KEY=
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=

# ── WhatsApp Notifications (choose ONE provider) ─────────────────────────────
# Option A: Twilio WhatsApp Business
# Set WHATSAPP_PROVIDER=twilio and fill in your Twilio credentials.
# Free sandbox: twilio.com/console/messaging/whatsapp/sandbox
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# Option B: Meta / Facebook WhatsApp Cloud API
# Set WHATSAPP_PROVIDER=meta and fill in your Meta credentials.
# WHATSAPP_PROVIDER=meta
# META_WHATSAPP_ACCESS_TOKEN=your_meta_access_token
# META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Option C: Local WhatsApp API (e.g. whatsapp-web.js self-hosted)
# WHATSAPP_PROVIDER=local
# LOCAL_WHATSAPP_API_URL=http://localhost:3001
# LOCAL_WHATSAPP_API_KEY=your_local_api_key
# LOCAL_WHATSAPP_BUSINESS_NUMBER=+919999999999

# Events that trigger WhatsApp notifications (comma-separated, leave blank to disable)
# Available: leave_submitted,leave_decision,payslip_ready,salary_credited,
#            roster_published,onboarding_welcome,attendance_absent
WHATSAPP_ENABLED_EVENTS=leave_decision,payslip_ready,salary_credited

# ── Cloudinary (optional) — employee profile photo cloud storage ──────────────
# Free tier: 25 GB storage + 25 GB bandwidth/month, no credit card required
# Sign up at https://cloudinary.com/users/register_free
# When these 3 vars are set, photos are stored on Cloudinary instead of local disk.
# Leave blank to use local filesystem (default for local dev).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
