NODE_ENV=development
PORT=5055
FRONTEND_URL=http://localhost:8080

ACTIVE_DB_PROVIDER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_staging_db
DB_POOL_MAX=10

JWT_SECRET=replace-with-strong-local-jwt-secret-at-least-32-chars
PORTAL_JWT_SECRET=replace-with-strong-local-portal-secret-at-least-32-chars
PAYROLL_BANK_KEY=replace-with-strong-bank-key
ENCRYPTION_KEY=replace-with-64-hex-character-key

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=MAS Callnet HRMS

BILL_DB_HOST=127.0.0.1
BILL_DB_PORT=3306
BILL_DB_USER=your_bill_db_user
BILL_DB_PASSWORD=your_bill_db_password
BILL_DB_NAME=db_bill

DIALER_DB_HOST=127.0.0.1
DIALER_DB_PORT=3306
DIALER_DB_USER=your_dialer_db_user
DIALER_DB_PASSWORD=your_dialer_db_password
DIALER_DB_NAME=dialer_db

LEGACY_MYSQL_HOST=127.0.0.1
LEGACY_MYSQL_PORT=3306
LEGACY_MYSQL_USER=your_legacy_user
LEGACY_MYSQL_PASSWORD=your_legacy_password
LEGACY_MYSQL_DATABASE=db_bill
LEGACY_MYSQL_LOCAL_ADDRESS=

LMS_DB_HOST=127.0.0.1
LMS_DB_PORT=3306
LMS_DB_USER=your_lms_user
LMS_DB_PASSWORD=your_lms_password
LMS_DB_NAME=lms_mcn

NCOSEC_DB_HOST=127.0.0.1
NCOSEC_DB_PORT=1433
NCOSEC_DB_USER=your_ncosec_user
NCOSEC_DB_PASSWORD=your_ncosec_password
NCOSEC_DB_NAME=NCOSEC
NCOSEC_DB_ENCRYPT=false

BGV_WEBHOOK_SECRET=replace-with-bgv-webhook-secret
ATS_FORM_API_KEY=replace-with-ats-form-api-key
INFINITY_AI_API_KEY=
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=
