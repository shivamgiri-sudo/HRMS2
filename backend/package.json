{
  "name": "mcn-hrms-backend",
  "version": "1.0.0",
  "description": "MCN HRMS production-safe backend API with migration-safe repository architecture",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmitOnError false 2>/dev/null || tsc --noEmitOnError false",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dashboard:audit": "tsx scripts/dashboard-data-audit.ts",
    "dashboard:audit:mas47814": "tsx scripts/dashboard-data-audit.ts mas47814",
    "seed:demo": "tsx scripts/seed-demo-auth.ts",
    "migrate:fresh:test": "tsx scripts/migrate-fresh-test.ts",
    "phase2:describe": "tsx scripts/phase2-describe.ts",
    "phase2:smoke": "npm run phase2:smoke:live:dangerous",
    "phase2:smoke:live:dangerous": "tsx scripts/smoke/hrms2-lifecycle-smoke.ts",
    "lms:backfill-identities": "tsx scripts/backfill-lms-identities.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@pdf-lib/standard-fonts": "^1.0.0",
    "@vladmandic/face-api": "^1.7.15",
    "archiver": "^8.0.0",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.2.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "mssql": "^12.5.5",
    "multer": "^2.1.1",
    "mysql2": "^3.11.5",
    "nodemailer": "^9.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "pizzip": "^3.2.0",
    "sharp": "^0.35.3",
    "tesseract.js": "^7.0.0",
    "twilio": "^6.0.2",
    "uuid": "^14.0.1",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/handlebars": "^4.0.40",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/mssql": "^12.3.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "@types/twilio": "^3.19.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.7",
    "ssh2": "^1.17.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.7"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
