# Backup files
*.bak

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.env
.vercel

# Local dev tools with credentials — never commit
backend/mysql-tunnel.cjs
backend/*.tunnel.cjs

# Local disk uploads — never commit uploaded files
backend/uploads/
backend/private-storage/

# Backend env files with credentials — never commit
backend/.env
backend/.env.production
backend/.env.test
backend/.env.backup
backups/
.env
.claude/settings.json

# Playwright test output — never commit
playwright-report/
playwright-results.json
test-results/
.tmp-backend.err
tools/schema-auditor/dist/
tools/schema-auditor/logs/
tools/schema-auditor/reports/*
!tools/schema-auditor/reports/.gitkeep
tools/schema-auditor/snapshots/*
!tools/schema-auditor/snapshots/.gitkeep
tools/schema-auditor/.env.schema-auditor
tools/schema-auditor/.env.schema-auditor.local
